@model QLSanBongMini.Web.Services.DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Tổng quan</h2>
    <a asp-controller="DatSan" asp-action="Create" class="btn btn-success">+ Đặt sân mới</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Sân hoạt động</div>
                <div class="fs-2 fw-bold text-success">@Model.TongSan</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Lịch hôm nay</div>
                <div class="fs-2 fw-bold">@Model.LichHomNay</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Lịch tháng này</div>
                <div class="fs-2 fw-bold">@Model.LichThangNay</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Doanh thu tháng</div>
                <div class="fs-4 fw-bold text-primary">@Model.DoanhThuThang.ToString("N0") đ</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Lịch đặt gần đây</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Ngày</th>
                            <th>Sân</th>
                            <th>Khách</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DatSanGanDay)
                        {
                            <tr>
                                <td>@item.NgayDat.ToString("dd/MM/yyyy")<br /><small>@item.GioBatDau.ToString(@"hh\:mm") - @item.GioKetThuc.ToString(@"hh\:mm")</small></td>
                                <td>@item.San.TenSan</td>
                                <td>@item.KhachHang.HoTen</td>
                                <td><span class="badge bg-secondary">@TrangThaiDatSan.Labels.GetValueOrDefault(item.TrangThai, item.TrangThai)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Sân được đặt nhiều (tháng này)</div>
            <ul class="list-group list-group-flush">
                @if (!Model.SanDuocDatNhieu.Any())
                {
                    <li class="list-group-item text-muted">Chưa có dữ liệu</li>
                }
                @foreach (var item in Model.SanDuocDatNhieu)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@item.TenSan</span>
                        <span class="badge bg-success">@item.SoLuot lượt</span>
                    </li>
                }
            </ul>
        </div>
        <div class="mt-3">
            <a asp-controller="LichSan" asp-action="Index" class="btn btn-outline-success w-100">Xem lịch sân hôm nay</a>
        </div>
    </div>
</div>
