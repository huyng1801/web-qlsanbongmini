@model IEnumerable<QLSanBongMini.Web.Models.Entities.KhungGio>
@{
    ViewData["Title"] = "Khung giờ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Khung giờ</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm khung giờ</a>
</div>

<div class="card border-0 shadow-sm">
    <table class="table mb-0">
        <thead><tr><th>Tên khung</th><th>Bắt đầu</th><th>Kết thúc</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TenKhung</td>
                    <td>@item.GioBatDau.ToString(@"hh\:mm")</td>
                    <td>@item.GioKetThuc.ToString(@"hh\:mm")</td>
                    <td class="text-end"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
