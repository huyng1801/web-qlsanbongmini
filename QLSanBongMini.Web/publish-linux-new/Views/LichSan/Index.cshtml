@model QLSanBongMini.Web.Models.ViewModels.LichSanViewModel
@{
    ViewData["Title"] = "Lịch sân";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lịch sân</h2>
    <form method="get" class="d-flex gap-2">
        <input type="date" name="ngay" value="@Model.NgayXem.ToString("yyyy-MM-dd")" class="form-control" />
        <button type="submit" class="btn btn-outline-success">Xem</button>
    </form>
</div>

<div class="mb-3">
    <span class="badge bg-success me-2">Trống</span>
    <span class="badge bg-danger me-2">Đã đặt</span>
    <span class="badge bg-warning text-dark">Bảo trì</span>
</div>

<div class="card border-0 shadow-sm overflow-auto">
    <table class="table table-bordered mb-0 text-center align-middle" style="min-width: 800px;">
        <thead class="table-success">
            <tr>
                <th class="text-start">Sân</th>
                @foreach (var khung in Model.KhungGios)
                {
                    <th>
                        @khung.TenKhung<br />
                        <small>@khung.GioBatDau.ToString(@"hh\:mm")-@khung.GioKetThuc.ToString(@"hh\:mm")</small>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var san in Model.Sans)
            {
                <tr>
                    <td class="text-start fw-semibold">
                        @san.TenSan
                        @if (san.TrangThai == TrangThaiSan.BaoTri)
                        {
                            <span class="badge bg-warning text-dark">Bảo trì</span>
                        }
                    </td>
                    @foreach (var khung in Model.KhungGios)
                    {
                        var dat = Model.ODatSan.GetValueOrDefault((san.Id, khung.Id));
                        if (san.TrangThai == TrangThaiSan.BaoTri)
                        {
                            <td class="bg-warning bg-opacity-25">—</td>
                        }
                        else if (dat != null)
                        {
                            <td class="bg-danger bg-opacity-10">
                                <small class="fw-semibold">@dat.KhachHang.HoTen</small><br />
                                <small>@dat.GioBatDau.ToString(@"hh\:mm")-@dat.GioKetThuc.ToString(@"hh\:mm")</small><br />
                                <a asp-controller="DatSan" asp-action="Details" asp-route-id="@dat.Id" class="btn btn-sm btn-outline-danger mt-1">Xem</a>
                            </td>
                        }
                        else
                        {
                            <td class="bg-success bg-opacity-10">
                                <a asp-controller="DatSan" asp-action="Create"
                                   asp-route-sanId="@san.Id"
                                   asp-route-ngay="@Model.NgayXem.ToString("yyyy-MM-dd")"
                                   asp-route-khungGioId="@khung.Id"
                                   class="btn btn-sm btn-success">Đặt</a>
                            </td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
