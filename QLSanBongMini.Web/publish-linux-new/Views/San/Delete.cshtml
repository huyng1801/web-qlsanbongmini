@model QLSanBongMini.Web.Models.Entities.San
@{
    ViewData["Title"] = "Xóa sân";
}

<h2 class="text-danger">Xác nhận xóa sân</h2>
<p>Bạn có chắc muốn xóa sân <strong>@Model.TenSan</strong>?</p>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
