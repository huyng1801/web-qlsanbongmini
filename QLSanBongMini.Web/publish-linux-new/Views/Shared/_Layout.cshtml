<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QL Sân Bóng Mini</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">⚽ QL Sân Bóng Mini</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Tổng quan</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="LichSan" asp-action="Index">Lịch sân</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="DatSan" asp-action="Index">Đặt sân</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="KhachHang" asp-action="Index">Khách hàng</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="San" asp-action="Index">Quản lý sân</a></li>
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Cài đặt</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="KhungGio" asp-action="Index">Khung giờ</a></li>
                                        <li><a class="dropdown-item" asp-controller="BangGia" asp-action="Index">Bảng giá</a></li>
                                        <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="Index">Người dùng</a></li>
                                    </ul>
                                </li>
                            }
                        </ul>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-flex">
                            @Html.AntiForgeryToken()
                            <span class="navbar-text text-white me-3">@User.Identity.Name</span>
                            <button type="submit" class="btn btn-outline-light btn-sm">Đăng xuất</button>
                        </form>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container py-4">
        <partial name="_Alerts" />
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top py-3 mt-auto bg-white">
        <div class="container text-muted small">
            &copy; @DateTime.Now.Year - Hệ thống quản lý sân bóng đá mini | ĐH Trà Vinh
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
