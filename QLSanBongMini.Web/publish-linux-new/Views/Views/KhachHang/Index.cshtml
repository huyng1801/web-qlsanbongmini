@model IEnumerable<QLSanBongMini.Web.Models.Entities.KhachHang>
@{
    ViewData["Title"] = "Khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Khách hàng</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm khách</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="q" value="@ViewBag.Q" class="form-control" placeholder="Tìm tên hoặc SĐT..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-success">Tìm</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <table class="table table-hover mb-0">
        <thead><tr><th>Họ tên</th><th>SĐT</th><th>Ghi chú</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.HoTen</td>
                    <td>@item.SoDienThoai</td>
                    <td>@item.GhiChu</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
