@model IEnumerable<(QLSanBongMini.Web.Models.ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý người dùng</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm tài khoản</a>
</div>

<div class="card border-0 shadow-sm">
    <table class="table table-hover mb-0">
        <thead><tr><th>Tên đăng nhập</th><th>Họ tên</th><th>Vai trò</th><th>Trạng thái</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.User.UserName</td>
                    <td>@item.User.HoTen</td>
                    <td>@string.Join(", ", item.Roles)</td>
                    <td>@(item.User.DangHoatDong ? "Hoạt động" : "Khóa")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.User.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
