@model IEnumerable<QLSanBongMini.Web.Models.Entities.San>
@{
    ViewData["Title"] = "Quản lý sân";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý sân</h2>
    @if (User.IsInRole(AppRoles.Admin))
    {
        <a asp-action="Create" class="btn btn-success">+ Thêm sân</a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Tên sân</th>
                    <th>Loại</th>
                    <th>Trạng thái</th>
                    <th>Mô tả</th>
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <th></th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.TenSan</td>
                        <td>@item.LoaiSan</td>
                        <td>
                            <span class="badge @(item.TrangThai == TrangThaiSan.HoatDong ? "bg-success" : "bg-warning text-dark")">
                                @TrangThaiSan.Labels.GetValueOrDefault(item.TrangThai, item.TrangThai)
                            </span>
                        </td>
                        <td>@item.MoTa</td>
                        @if (User.IsInRole(AppRoles.Admin))
                        {
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
