@model QLSanBongMini.Web.Models.Entities.San
@{
    ViewData["Title"] = "Thêm sân";
}

<h2>Thêm sân mới</h2>
<form asp-action="Create" method="post" class="card border-0 shadow-sm p-4 mt-3">
    <div class="mb-3">
        <label asp-for="TenSan" class="form-label"></label>
        <input asp-for="TenSan" class="form-control" />
        <span asp-validation-for="TenSan" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="LoaiSan" class="form-label"></label>
        <select asp-for="LoaiSan" class="form-select">
            <option value="5v5">5 người (5v5)</option>
            <option value="7v7">7 người (7v7)</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="TrangThai" class="form-label"></label>
        <select asp-for="TrangThai" class="form-select">
            <option value="@TrangThaiSan.HoatDong">Hoạt động</option>
            <option value="@TrangThaiSan.BaoTri">Bảo trì</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="MoTa" class="form-label"></label>
        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
    </div>
    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
