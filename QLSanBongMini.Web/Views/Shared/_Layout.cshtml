@using QLSanBongMini.Web.Models
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool IsNavActive(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
    bool IsSettingsActive() =>
        IsNavActive("KhungGio") || IsNavActive("BangGia") || IsNavActive("NguoiDung");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QL Sân Bóng Mini</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sb-navbar">
            <div class="container">
                <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-dribbble me-1"></i> QL Sân Bóng Mini
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link @(IsNavActive("Dashboard") ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Tổng quan</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsNavActive("LichSan") ? "active" : "")" asp-controller="LichSan" asp-action="Index"><i class="bi bi-calendar3 me-1"></i>Lịch sân</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsNavActive("DatSan") ? "active" : "")" asp-controller="DatSan" asp-action="Index"><i class="bi bi-calendar-check me-1"></i>Đặt sân</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsNavActive("KhachHang") ? "active" : "")" asp-controller="KhachHang" asp-action="Index"><i class="bi bi-people me-1"></i>Khách hàng</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(IsNavActive("San") ? "active" : "")" asp-controller="San" asp-action="Index"><i class="bi bi-geo-alt me-1"></i>Quản lý sân</a>
                            </li>
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle @(IsSettingsActive() ? "active" : "")" href="#" data-bs-toggle="dropdown"><i class="bi bi-gear me-1"></i>Cài đặt</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item @(IsNavActive("KhungGio") ? "active" : "")" asp-controller="KhungGio" asp-action="Index"><i class="bi bi-clock me-2"></i>Khung giờ</a></li>
                                        <li><a class="dropdown-item @(IsNavActive("BangGia") ? "active" : "")" asp-controller="BangGia" asp-action="Index"><i class="bi bi-currency-dollar me-2"></i>Bảng giá</a></li>
                                        <li><a class="dropdown-item @(IsNavActive("NguoiDung") ? "active" : "")" asp-controller="NguoiDung" asp-action="Index"><i class="bi bi-person-badge me-2"></i>Người dùng</a></li>
                                    </ul>
                                </li>
                            }
                        </ul>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-flex align-items-center">
                            @Html.AntiForgeryToken()
                            <span class="navbar-text text-white me-3 small">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                            </button>
                        </form>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container sb-main">
        <partial name="_Alerts" />
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="sb-footer mt-auto">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year — Hệ thống quản lý sân bóng đá mini</span>
            <span class="text-muted">Đồ án ASP.NET — ĐH Trà Vinh</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
