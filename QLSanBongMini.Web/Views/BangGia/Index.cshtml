@model IEnumerable<QLSanBongMini.Web.Models.Entities.BangGia>
@{
    ViewData["Title"] = "Bảng giá";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Bảng giá</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm giá</a>
</div>

<div class="card border-0 shadow-sm">
    <table class="table table-hover mb-0">
        <thead>
            <tr><th>Sân</th><th>Khung giờ</th><th>Loại ngày</th><th>Giá</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.San.TenSan</td>
                    <td>@item.KhungGio.TenKhung</td>
                    <td>@(item.LaCuoiTuan ? "Cuối tuần" : "Ngày thường")</td>
                    <td class="fw-semibold">@item.Gia.ToString("N0") đ</td>
                    <td class="text-end"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
