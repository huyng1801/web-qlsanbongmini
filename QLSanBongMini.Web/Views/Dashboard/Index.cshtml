@model QLSanBongMini.Web.Services.DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="sb-page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
        <h2 class="mb-1">Tổng quan</h2>
        <p class="sb-subtitle mb-0">Thống kê hoạt động sân bóng — @DateTime.Now.ToString("dd/MM/yyyy")</p>
    </div>
    <a asp-controller="DatSan" asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i> Đặt sân mới
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card sb-stat">
            <div class="card-body">
                <div class="sb-stat-icon green"><i class="bi bi-geo-alt-fill"></i></div>
                <div class="stat-label">Sân hoạt động</div>
                <div class="stat-value text-success">@Model.TongSan</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card sb-stat">
            <div class="card-body">
                <div class="sb-stat-icon blue"><i class="bi bi-calendar-day"></i></div>
                <div class="stat-label">Lịch hôm nay</div>
                <div class="stat-value">@Model.LichHomNay</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card sb-stat">
            <div class="card-body">
                <div class="sb-stat-icon orange"><i class="bi bi-calendar-month"></i></div>
                <div class="stat-label">Lịch tháng này</div>
                <div class="stat-value">@Model.LichThangNay</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card sb-stat">
            <div class="card-body">
                <div class="sb-stat-icon purple"><i class="bi bi-cash-stack"></i></div>
                <div class="stat-label">Doanh thu tháng</div>
                <div class="stat-value money">@Model.DoanhThuThang.ToString("N0") đ</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="sb-card card">
            <div class="card-header"><i class="bi bi-list-ul me-2"></i>Lịch đặt gần đây</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Ngày / Giờ</th>
                            <th>Sân</th>
                            <th>Khách hàng</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DatSanGanDay)
                        {
                            <tr>
                                <td>
                                    <span class="fw-semibold">@item.NgayDat.ToString("dd/MM/yyyy")</span><br />
                                    <small class="text-muted">@item.GioBatDau.ToString(@"hh\:mm") - @item.GioKetThuc.ToString(@"hh\:mm")</small>
                                </td>
                                <td>@item.San.TenSan</td>
                                <td>@item.KhachHang.HoTen</td>
                                <td>
                                    <span class="badge rounded-pill bg-secondary">
                                        @TrangThaiDatSan.Labels.GetValueOrDefault(item.TrangThai, item.TrangThai)
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="sb-card card">
            <div class="card-header"><i class="bi bi-trophy me-2"></i>Sân được đặt nhiều (tháng này)</div>
            <ul class="list-group list-group-flush">
                @if (!Model.SanDuocDatNhieu.Any())
                {
                    <li class="list-group-item text-muted py-3">Chưa có dữ liệu</li>
                }
                @foreach (var item in Model.SanDuocDatNhieu)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-dribbble text-success me-2"></i>@item.TenSan</span>
                        <span class="badge bg-success rounded-pill">@item.SoLuot lượt</span>
                    </li>
                }
            </ul>
        </div>
        <a asp-controller="LichSan" asp-action="Index" class="btn btn-outline-success w-100 mt-3 py-2">
            <i class="bi bi-calendar3 me-1"></i> Xem lịch sân hôm nay
        </a>
    </div>
</div>
