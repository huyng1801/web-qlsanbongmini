@model QLSanBongMini.Web.Models.ViewModels.ThanhToanFormViewModel
@{
    ViewData["Title"] = "Thanh toán";
    var datSan = ViewBag.DatSan as QLSanBongMini.Web.Models.Entities.DatSan;
}

<h2>Thanh toán đặt sân #@Model.DatSanId</h2>
@if (datSan != null)
{
    <p class="text-muted">@datSan.San.TenSan — @datSan.KhachHang.HoTen — @datSan.NgayDat.ToString("dd/MM/yyyy")</p>
}

<form asp-action="ThanhToan" method="post" class="card border-0 shadow-sm p-4 mt-3">
    <input type="hidden" asp-for="DatSanId" />
    <input type="hidden" asp-for="TongTienDatSan" />
    <p>Tổng tiền đặt sân: <strong>@Model.TongTienDatSan.ToString("N0") đ</strong></p>
    <div class="mb-3">
        <label asp-for="SoTien" class="form-label"></label>
        <input asp-for="SoTien" class="form-control" />
        <span asp-validation-for="SoTien" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="HinhThuc" class="form-label"></label>
        <select asp-for="HinhThuc" class="form-select">
            @foreach (var kv in HinhThucThanhToan.Labels)
            {
                <option value="@kv.Key">@kv.Value</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="TrangThai" class="form-label"></label>
        <select asp-for="TrangThai" class="form-select">
            @foreach (var kv in TrangThaiThanhToan.Labels)
            {
                <option value="@kv.Key">@kv.Value</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="GhiChu" class="form-label"></label>
        <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
    </div>
    <button type="submit" class="btn btn-success">Lưu thanh toán</button>
    <a asp-action="Details" asp-route-id="@Model.DatSanId" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
