@model QLSanBongMini.Web.Models.ViewModels.DatSanFormViewModel
@{
    ViewData["Title"] = "Đặt sân mới";
}

<h2>Đặt sân mới</h2>
<form asp-action="Create" method="post" class="card border-0 shadow-sm p-4 mt-3" id="formDatSan">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="SanId" class="form-label"></label>
            <select asp-for="SanId" class="form-select" asp-items="ViewBag.SanId" id="SanId"></select>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="KhachHangId" class="form-label"></label>
            <select asp-for="KhachHangId" class="form-select" asp-items="ViewBag.KhachHangId"></select>
            <div class="form-text"><a asp-controller="KhachHang" asp-action="Create" target="_blank">+ Thêm khách mới</a></div>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="NgayDat" class="form-label"></label>
            <input asp-for="NgayDat" type="date" class="form-control" id="NgayDat" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="GioBatDau" class="form-label"></label>
            <input asp-for="GioBatDau" type="time" class="form-control" id="GioBatDau" value="@Model.GioBatDau.ToString(@"hh\:mm")" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="GioKetThuc" class="form-label"></label>
            <input asp-for="GioKetThuc" type="time" class="form-control" id="GioKetThuc" value="@Model.GioKetThuc.ToString(@"hh\:mm")" />
        </div>
        <div class="col-md-12 mb-3">
            <label asp-for="GhiChu" class="form-label"></label>
            <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
        </div>
        <div class="col-md-12 mb-3">
            <div class="alert alert-info mb-0">
                Tổng tiền dự kiến: <strong id="TongTienLabel">@Model.TongTien.ToString("N0")</strong> đ
            </div>
            <input type="hidden" asp-for="TongTien" id="TongTien" />
        </div>
    </div>
    <button type="submit" class="btn btn-success">Lưu lịch đặt</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function capNhatTien() {
            const sanId = $('#SanId').val();
            const ngay = $('#NgayDat').val();
            const batDau = $('#GioBatDau').val();
            const ketThuc = $('#GioKetThuc').val();
            if (!sanId || !ngay || !batDau || !ketThuc) return;
            $.get('@Url.Action("TinhTien")', { sanId, ngayDat: ngay, gioBatDau: batDau, gioKetThuc: ketThuc }, function (data) {
                $('#TongTienLabel').text(data.tongTien.toLocaleString('vi-VN'));
                $('#TongTien').val(data.tongTien);
            });
        }
        $('#SanId, #NgayDat, #GioBatDau, #GioKetThuc').on('change', capNhatTien);
    </script>
}
