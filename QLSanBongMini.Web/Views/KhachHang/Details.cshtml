@model QLSanBongMini.Web.Models.Entities.KhachHang
@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<h2>@Model.HoTen</h2>
<p><strong>SĐT:</strong> @Model.SoDienThoai</p>
<p><strong>Ghi chú:</strong> @(Model.GhiChu ?? "-")</p>

<h4 class="mt-4">Lịch sử đặt sân</h4>
<div class="card border-0 shadow-sm">
    <table class="table mb-0">
        <thead><tr><th>Ngày</th><th>Sân</th><th>Giờ</th><th>Trạng thái</th><th>Tiền</th></tr></thead>
        <tbody>
            @foreach (var item in Model.DatSans.OrderByDescending(x => x.NgayDat))
            {
                <tr>
                    <td>@item.NgayDat.ToString("dd/MM/yyyy")</td>
                    <td>@item.San.TenSan</td>
                    <td>@item.GioBatDau.ToString(@"hh\:mm") - @item.GioKetThuc.ToString(@"hh\:mm")</td>
                    <td>@TrangThaiDatSan.Labels.GetValueOrDefault(item.TrangThai, item.TrangThai)</td>
                    <td>@item.TongTien.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a asp-action="Index" class="btn btn-secondary mt-3">Quay lại</a>
