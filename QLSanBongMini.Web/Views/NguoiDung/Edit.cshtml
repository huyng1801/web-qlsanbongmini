@model QLSanBongMini.Web.Models.ViewModels.UserFormViewModel
@{
    ViewData["Title"] = "Sửa người dùng";
}

<h2>Sửa tài khoản</h2>
<form asp-action="Edit" method="post" class="card border-0 shadow-sm p-4 mt-3">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" readonly />
    </div>
    <div class="mb-3">
        <label asp-for="HoTen" class="form-label"></label>
        <input asp-for="HoTen" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" placeholder="Để trống nếu không đổi" />
    </div>
    <div class="mb-3">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" class="form-select">
            <option value="@AppRoles.Admin">Admin</option>
            <option value="@AppRoles.NhanVien">Nhân viên</option>
        </select>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="DangHoatDong" class="form-check-input" />
        <label asp-for="DangHoatDong" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-success">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
